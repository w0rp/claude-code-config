{
  "env": {
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "disableAllHooks": true,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "./.env",
        "./.env.*",
        "./**/.env",
        "./**/.env.*",
        "./**/config.toml",
        "./secrets/**",
        "./.claude/**",
        "~/.aws/**",
        "~/.ssh/**",
        "~/.gnupg/**",
        "~/.config/gh/**",
        "~/.config/git/**",
        "~/.npmrc",
        "~/.pypirc",
        "~/.netrc",
        "~/.kube/**"
      ],
      "denyWrite": [
        "./.git/**",
        "./.claude/**"
      ]
    },
    "network": {
      "allowedDomains": []
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(./run_tests.sh:*)",
      "Bash(.venv/bin/pyright:*)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(diff *)",
      "Bash(git branch --list *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git reflog)",
      "Bash(git reflog *)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git tag --list)",
      "Bash(git tag --list *)",
      "Bash(git tag -l)",
      "Bash(git tag -l *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(yarn lint)",
      "Bash(yarn lint *)",
      "Bash(yarn lint:files)",
      "Bash(yarn lint:files *)",
      "Bash(yarn types:build)",
      "Bash(yarn types:build *)"
    ],
    "deny": [
      "Bash(./cdk-wrapper.sh *)",
      "Bash(./cdk.sh *)",
      "Bash(.venv/bin/python3 *)",
      "Bash(.venv/bin/python *)",
      "Bash(cdk *)",
      "Bash(find *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(pipx *)",
      "Bash(python3 *)",
      "Bash(python *)"
    ]
  }
}
